generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  PATIENT
  THERAPIST
  PSYCHIATRIST
  COACH
  ADMIN
}

enum ProviderType {
  THERAPIST
  PSYCHIATRIST
  COACH
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum SessionStatus {
  PENDING_PAYMENT
  CONFIRMED
  LIVE
  COMPLETED
  NO_SHOW
  CANCELLED
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum UserProvider {
  LOCAL
  GOOGLE
  PHONE
}

// ============ USERS ============

model User {
  id                            String       @id @default(uuid())
  name                          String?
  email                         String?      @unique
  phone                         String?      @unique
  firstName                     String       @default("")
  lastName                      String       @default("")
  role                          UserRole
  provider                      UserProvider @default(LOCAL)
  passwordHash                  String?
  googleId                      String?      @unique
  profileImageKey               String?
  profileImageUrl               String?
  emailVerified                 Boolean      @default(false)
  phoneVerified                 Boolean      @default(false)
  emailVerificationOtpHash      String?
  emailVerificationOtpExpiresAt DateTime?
  phoneVerificationOtpHash      String?
  phoneVerificationOtpExpiresAt DateTime?
  passwordResetOtpHash          String?
  passwordResetOtpExpiresAt     DateTime?
  mfaEnabled                    Boolean      @default(false)
  mfaSecret                     String?
  failedLoginAttempts           Int          @default(0)
  lockUntil                     DateTime?
  lastLoginAt                   DateTime?
  passwordChangedAt             DateTime?
  isDeleted                     Boolean      @default(false)
  deletedAt                     DateTime?
  createdAt                     DateTime     @default(now())
  updatedAt                     DateTime     @updatedAt

  // Relations
  therapistSessions         CBTSessionTemplate[]      @relation("TherapistSessions")
  patientSessions           PatientSession[]
  sessionResponses          PatientSessionResponse[]
  patientProfile            PatientProfile?
  therapyBookings           TherapySession[]
  financialPatientSessions  FinancialSession[]        @relation("FinancialPatient")
  financialProviderSessions FinancialSession[]        @relation("FinancialProvider")
  patientLeads              Lead[]                    @relation("LeadPatient")
  providerLeads             Lead[]                    @relation("LeadProvider")
  providerWallet            ProviderWallet?           @relation("ProviderWalletOwner")
  subscriptions             MarketplaceSubscription[] @relation("UserSubscriptions")
  financialAuditEvents      FinancialAuditLog[]       @relation("UserFinancialAudits")
  authSessions              AuthSession[]
  authAuditLogs             AuthAuditLog[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([isDeleted])
  @@map("users")
}

model AuthSession {
  id               String   @id @default(uuid())
  userId           String
  jti              String   @unique
  refreshTokenHash String
  ipAddress        String?
  userAgent        String?
  device           String?
  revokedAt        DateTime?
  expiresAt        DateTime
  lastActiveAt     DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([userId, expiresAt])
  @@map("auth_sessions")
}

model AuthAuditLog {
  id        String   @id @default(uuid())
  userId    String?
  event     String
  status    String
  email     String?
  phone     String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([event, createdAt])
  @@map("auth_audit_logs")
}

// ============ CBT SESSION TEMPLATES ============

model CBTSessionTemplate {
  id                       String        @id @default(uuid())
  title                    String
  description              String?
  isOfficial               Boolean       @default(false)
  originTemplateId         String?
  visibility               String        @default("ORG")
  latestPublishedVersionId String?
  version                  Int           @default(1)
  status                   SessionStatus @default(DRAFT)
  category                 String? // e.g., "Anxiety", "Depression", "Sleep"
  targetAudience           String? // e.g., "Adults", "Teenagers"
  estimatedDuration        Int? // in minutes

  // Metadata
  therapistId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?
enum PaymentType {
  SESSION
  SUBSCRIPTION
  LEAD_PURCHASE
  CONTENT_PURCHASE
  THERAPIST_PLAN
}

enum SubscriptionStatus {
  CREATED
  AUTHENTICATED
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum SubscriptionTier {
  FREE
  BASIC
  PREMIUM
}

enum LeadStatus {
  AVAILABLE
  PURCHASED
  CONTACTED
  CONVERTED
  EXPIRED
}

enum PayoutStatus {
  REQUESTED
  APPROVED
  REJECTED
  PROCESSING
  PAID
  FAILED
}

enum NotificationType {
  EMAIL
  SMS
  WHATSAPP
  IN_APP
  PUSH
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CrisisLevel {
  NONE
  LOW
  MODERATE
  HIGH
  SEVERE
}

enum ContentType {
  SOUND_TRACK
  SLEEP_PROGRAM
  MEDITATION
  ARTICLE
  VIDEO
  WORKSHEET
}

// ============================================
// CORE USER SYSTEM
// ============================================

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  phone             String?   @unique
  passwordHash      String
  firstName         String
  lastName          String
  role              UserRole
  emailVerified     Boolean   @default(false)
  phoneVerified     Boolean   @default(false)
  avatarUrl         String?
  preferredLanguage String    @default("en")
  isActive          Boolean   @default(true)
  lastLoginAt       DateTime?
  organizationId    String?   // For corporate employees
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  profile               UserProfile?
  patientProfile        PatientProfile?
  providerProfile       ProviderProfile?
  sessions              Session[]                 @relation("PatientSessions")
  providerSessions      Session[]                 @relation("ProviderSessions")
  payments              Payment[]
  subscriptions         Subscription[]
  notifications         Notification[]
  refreshTokens         RefreshToken[]
  auditLogs             AuditLog[]
  leadPurchases         LeadPurchase[]
  contentPurchases      ContentPurchase[]
  aiChatMessages        AIChatMessage[]
  moodEntries           MoodEntry[]
  organization          Organization?             @relation(fields: [organizationId], references: [id])
  createdLeads          Lead[]                    @relation("LeadCreator")
  assessments           Assessment[]
  walletTransactions    WalletTransaction[]
  payoutRequests        PayoutRequest[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([organizationId])
  @@index([isActive])
  @@map("users")
}

model UserProfile {
  id                String    @id @default(uuid())
  userId            String    @unique
  dateOfBirth       DateTime?
  gender            String?
  city              String?
  state             String?
  country           String    @default("India")
  emergencyContact  Json?     // { name, phone, relation }
  medicalHistory    Json?     // Encrypted
  preferences       Json?     // UI preferences, timezone, etc.
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  ipAddress String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================
// PROVIDER SYSTEM
// ============================================

model ProviderProfile {
  id                  String             @id @default(uuid())
  userId              String             @unique
  providerType        ProviderType
  licenseNumber       String
  licenseBody         String // RCI, MCI, etc.
  licenseVerified     Boolean            @default(false)
  verificationStatus  VerificationStatus @default(PENDING)
  verificationDate    DateTime?
  verificationNotes   String?
  specializations     Json               // ["anxiety", "depression", "trauma"]
  approaches          Json               // ["CBT", "DBT", "Psychodynamic"]
  languages           String[]
  sessionRate         Int // In rupees
  bio                 String?
  yearsExperience     Int?
  education           Json? // [{ degree, institution, year }]
  certifications      Json? // [{ name, issuer, year }]
  maxPatientsPerWeek  Int?
  isAcceptingPatients Boolean            @default(true)
  ratingAverage       Decimal?           @db.Decimal(3, 2)
  totalSessions       Int                @default(0)
  totalReviews        Int                @default(0)
  leadPlanId          String?
  bankAccount         Json? // Encrypted bank details
  panNumber           String? // Encrypted
  gstNumber           String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadPlan           LeadPlan?            @relation(fields: [leadPlanId], references: [id])
  availability       ProviderAvailability[]
  documents          ProviderDocument[]
  wallet             ProviderWallet?
  leads              Lead[]               @relation("AssignedLeads")

  @@index([providerType])
  @@index([licenseVerified])
  @@index([isAcceptingPatients])
  @@index([verificationStatus])
  @@map("provider_profiles")
}

model ProviderDocument {
  id         String   @id @default(uuid())
  providerId String
  documentType String // "license", "certificate", "id_proof"
  fileUrl    String
  fileName   String
  uploadedAt DateTime @default(now())
  verifiedAt DateTime?

  provider ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("provider_documents")
}

model ProviderAvailability {
  id           String   @id @default(uuid())
  providerId   String
  dayOfWeek    Int // 0-6 (Sunday to Saturday)
  startTime    String // "09:00"
  endTime      String // "17:00"
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  provider ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([dayOfWeek])
  @@map("provider_availability")
}

// ============================================
// WALLET & PAYOUT SYSTEM (CENTRALIZED MODEL)
// ============================================

model ProviderWallet {
  id                String   @id @default(uuid())
  providerId        String   @unique
  availableBalance  Int      @default(0) // In paise
  pendingBalance    Int      @default(0) // In paise
  lifetimeEarnings  Int      @default(0) // In paise
  totalWithdrawn    Int      @default(0) // In paise
  lastPayoutAt      DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  provider     ProviderProfile    @relation(fields: [providerId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
  payouts      PayoutRequest[]

  @@map("provider_wallets")
}

model WalletTransaction {
  id              String   @id @default(uuid())
  walletId        String
  userId          String // Provider user ID
  type            String // "CREDIT", "DEBIT", "REFUND"
  amount          Int // In paise
  balanceBefore   Int
  balanceAfter    Int
  description     String
  referenceType   String? // "session", "payout", "adjustment"
  referenceId     String?
  metadata        Json?
  createdAt       DateTime @default(now())

  wallet ProviderWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([userId])
  @@index([createdAt])
  @@index([referenceType, referenceId])
  @@map("wallet_transactions")
}

model PayoutRequest {
  id                    String        @id @default(uuid())
  walletId              String
  userId                String // Provider user ID
  amount                Int // In paise
  status                PayoutStatus  @default(REQUESTED)
  approvedBy            String?
  approvedAt            DateTime?
  rejectionReason       String?
  transactionReference  String? // From payment gateway
  processingFee         Int? // In paise
  netAmount             Int? // amount - processingFee
  paidAt                DateTime?
  failureReason         String?
  metadata              Json? // Bank details, etc.
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  wallet ProviderWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("payout_requests")
}

// ============================================
// PATIENT SYSTEM
// ============================================

model PatientProfile {
  id                      String    @id @default(uuid())
  userId                  String    @unique
  subscriptionTier        SubscriptionTier @default(FREE)
  matchedProviderIds      String[]  // Array of provider IDs from AI matching
  primaryConcerns         String[]  // ["anxiety", "depression"]
  preferredLanguages      String[]
  preferredProviderGender String? // "male", "female", "no_preference"
  preferredApproaches     String[] // ["CBT", "mindfulness"]
  emergencyContactName    String?
  emergencyContactPhone   String?
  consentGiven            Boolean   @default(false)
  consentDate             DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessments Assessment[]
  sessions    Session[]

  @@map("patient_profiles")
}

model Assessment {
  id             String      @id @default(uuid())
  userId         String
  patientId      String
  assessmentType String      @default("PHQ-9") // "PHQ-9", "GAD-7", etc.
  responses      Json        // Question responses
  score          Int?
  severity       String? // "minimal", "mild", "moderate", "severe"
  isCrisis       Boolean     @default(false)
  crisisLevel    CrisisLevel @default(NONE)
  recommendations Json? // AI-generated
  completedAt    DateTime    @default(now())

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  patientProfile PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([patientId])
  @@index([assessmentType])
  @@index([isCrisis])
  @@index([completedAt])
  @@map("assessments")
}

// ============================================
// SESSION SYSTEM
// ============================================

model Session {
  id                   String        @id @default(uuid())
  patientId            String
  providerId           String
  scheduledAt          DateTime
  duration             Int           @default(60) // minutes
  status               SessionStatus @default(PENDING_PAYMENT)
  fee                  Int // In paise
  platformCommission   Int // In paise
  providerEarning      Int // In paise
  agoraChannelName     String?       @unique
  agoraToken           String?
  startedAt            DateTime?
  endedAt              DateTime?
  noShowMarkedBy       String? // "patient" or "provider"
  noShowMarkedAt       DateTime?
  cancellationReason   String?
  cancelledAt          DateTime?
  sessionNotes         String? // Provider notes (encrypted)
  patientRating        Int?
  patientFeedback      String?
  providerRating       Int?
  providerFeedback     String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  patient  User @relation("PatientSessions", fields: [patientId], references: [id], onDelete: Cascade)
  provider User @relation("ProviderSessions", fields: [providerId], references: [id], onDelete: Cascade)
  patientProfile PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade, map: "sessions_patient_profile_fkey")

  @@unique([providerId, scheduledAt])
  @@index([patientId])
  @@index([providerId])
  @@index([scheduledAt])
  @@index([status])
  @@index([agoraChannelName])
  @@map("sessions")
}

// ============================================
// PAYMENT SYSTEM (CENTRALIZED MODEL)
// ============================================

model Payment {
  id                  String        @id @default(uuid())
  userId              String
  paymentType         PaymentType
  amount              Int // In paise
  currency            String        @default("INR")
  status              PaymentStatus @default(CREATED)
  razorpayOrderId     String?       @unique
  razorpayPaymentId   String?       @unique
  razorpaySignature   String?
  referenceType       String? // "session", "subscription", "lead", "content"
  referenceId         String?
  metadata            Json?
  failureReason       String?
  capturedAt          DateTime?
  refundedAt          DateTime?
  refundAmount        Int? // In paise
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([paymentType])
  @@index([status])
  @@index([razorpayOrderId])
  @@index([razorpayPaymentId])
  @@index([referenceType, referenceId])
  @@index([createdAt])
  @@map("payments")
}

// ============================================
// SUBSCRIPTION SYSTEM
// ============================================

model SubscriptionPlan {
  id                String           @id @default(uuid())
  name              String
  tier              SubscriptionTier @unique
  price             Int // Monthly price in paise
  features          Json // Feature list
  maxSessions       Int? // Per month
  aiChatEnabled     Boolean          @default(false)
  contentLibraryAccess Boolean       @default(false)
  prioritySupport   Boolean          @default(false)
  isActive          Boolean          @default(true)
  razorpayPlanId    String?          @unique
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String
  planId               String
  status               SubscriptionStatus @default(CREATED)
  razorpaySubscriptionId String?          @unique
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?
  cancellationReason   String?
  metadata             Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([planId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

// ============================================
// LEAD MARKETPLACE SYSTEM
// ============================================

model LeadPlan {
  id           String   @id @default(uuid())
  name         String
  description  String?
  leadsPerMonth Int
  price        Int // In paise
  priority     Int      @default(0)
  isActive     Boolean  @default(true)
  features     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  providers ProviderProfile[]
  purchases LeadPurchase[]

  @@map("lead_plans")
}

model Lead {
  id                         String     @id @default(uuid())
  patientId                  String
  createdById                String
  matchScore                 Int // 0-100
  previewData                Json // Non-PII preview
  fullData                   Json // Full data (encrypted)
  status                     LeadStatus @default(AVAILABLE)
  price                      Int // In paise (dynamic based on match score)
  providerId                 String? // Assigned when purchased
  purchasedAt                DateTime?
  contactedAt                DateTime?
  convertedAt                DateTime?
  patientAcceptanceDeadline  DateTime // 2-hour window
  expiresAt                  DateTime
  createdAt                  DateTime   @default(now())
  updatedAt                  DateTime   @updatedAt

  createdBy User           @relation("LeadCreator", fields: [createdById], references: [id])
  provider  ProviderProfile? @relation("AssignedLeads", fields: [providerId], references: [id])
  purchases LeadPurchase[]

  @@index([status])
  @@index([providerId])
  @@index([matchScore])
  @@index([patientAcceptanceDeadline])
  @@index([expiresAt])
  @@map("leads")
}

model LeadPurchase {
  id         String   @id @default(uuid())
  leadId     String
  providerId String
  planId     String?
  price      Int // In paise
  purchasedAt DateTime @default(now())
  metadata   Json?

  lead     Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  provider User      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  plan     LeadPlan? @relation(fields: [planId], references: [id])

  @@index([leadId])
  @@index([providerId])
  @@index([purchasedAt])
  @@map("lead_purchases")
}

// ============================================
// CONTENT LIBRARY
// ============================================

model Content {
  id          String      @id @default(uuid())
  title       String
  description String?
  contentType ContentType
  fileUrl     String?
  thumbnailUrl String?
  duration    Int? // In seconds
  price       Int? // In paise (null = free)
  isFree      Boolean     @default(false)
  isPremiumOnly Boolean   @default(false)
  tags        String[]
  category    String?
  rating      Decimal?    @db.Decimal(3, 2)
  totalViews  Int         @default(0)
  totalPurchases Int      @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  purchases ContentPurchase[]

  @@index([contentType])
  @@index([isFree])
  @@index([isPremiumOnly])
  @@index([isActive])
  @@map("content_library")
}

model ContentPurchase {
  id          String   @id @default(uuid())
  contentId   String
  userId      String
  price       Int // In paise
  purchasedAt DateTime @default(now())

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contentId, userId])
  @@index([userId])
  @@index([contentId])
  @@map("content_purchases")
}

// ============================================
// AI CHAT SYSTEM (CLAUDE)
// ============================================

model AIChatMessage {
  id        String   @id @default(uuid())
  userId    String
  role      String // "user" or "assistant"
  content   String
  metadata  Json? // Token count, model used, etc.
  crisisDetected Boolean @default(false)
  crisisLevel    CrisisLevel @default(NONE)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([crisisDetected])
  @@index([createdAt])
  @@map("ai_chat_messages")
}

// ============================================
// MOOD TRACKING
// ============================================

model MoodEntry {
  id        String   @id @default(uuid())
  userId    String
  mood      String // "happy", "sad", "anxious", etc.
  intensity Int // 1-10
  notes     String?
  triggers  String[]
  activities String[]
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@map("mood_entries")
}

// ============================================
// CORPORATE / B2B
// ============================================

model Organization {
  id            String   @id @default(uuid())
  name          String
  contactEmail  String
  contactPhone  String?
  address       Json?
  gstNumber     String?
  contractStart DateTime?
  contractEnd   DateTime?
  isActive      Boolean  @default(true)
  discount      Int      @default(0) // Percentage
  billingCycle  String   @default("monthly") // "monthly", "quarterly", "annually"
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employees       User[]
  corporateInvoices CorporateInvoice[]

  @@map("organizations")
}

model CorporateInvoice {
  id             String   @id @default(uuid())
  organizationId String
  invoiceNumber  String   @unique
  amount         Int // In paise
  taxAmount      Int? // In paise
  totalAmount    Int // In paise
  periodStart    DateTime
  periodEnd      DateTime
  dueDate        DateTime
  paidAt         DateTime?
  paymentStatus  String   @default("pending") // "pending", "paid", "overdue"
  fileUrl        String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([paymentStatus])
  @@index([dueDate])
  @@map("corporate_invoices")
}

// ============================================
// NOTIFICATION SYSTEM
// ============================================

model Notification {
  id        String               @id @default(uuid())
  userId    String
  type      NotificationType
  priority  NotificationPriority @default(MEDIUM)
  title     String
  body      String
  data      Json?
  channel   String? // email, sms, whatsapp, push
  sentAt    DateTime?
  readAt    DateTime?
  failedAt  DateTime?
  retryCount Int                 @default(0)
  createdAt DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([readAt])
  @@index([sentAt])
  @@index([priority])
  @@map("notifications")
}

// ============================================
// RBAC SYSTEM
// ============================================

model Permission {
  id          Int      @id @default(autoincrement())
  resource    String // "session", "payment", "user", etc.
  action      String // "create", "read", "update", "delete"
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  role         UserRole
  permissionId Int
  createdAt    DateTime   @default(now())

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@map("role_permissions")
}

// ============================================
// AUDIT & LOGGING
// ============================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String // "CREATE", "UPDATE", "DELETE", "LOGIN", etc.
  entityType String // "user", "session", "payment", etc.
  entityId   String?
  changes    Json? // Before/after diff
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// WEBHOOK LOGS (Idempotency)
// ============================================

model WebhookLog {
  id        String   @id @default(uuid())
  provider  String // "razorpay"
  eventId   String   @unique
  eventType String
  payload   Json
  signature String?
  verified  Boolean  @default(false)
  processed Boolean  @default(false)
  processedAt DateTime?
  errorMessage String?
  retryCount Int     @default(0)
  createdAt DateTime @default(now())

  @@index([provider, eventId])
  @@index([processed])
  @@index([createdAt])
  @@map("webhook_logs")
}

enum FinancialSessionStatus {
  PENDING_PAYMENT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  EXPIRED
  CANCELLED
}

enum FinancialPaymentStatus {
  INITIATED
  PENDING_CAPTURE
  CAPTURED
  FAILED
  REFUNDED
  PARTIAL_REFUNDED
}

enum WalletTxnType {
  CREDIT_PENDING
  RELEASE
  DEBIT_PAYOUT
  REVERSAL
  ADJUSTMENT
}

enum WalletTxnStatus {
  POSTED
  VOIDED
}

enum PayoutStatus {
  REQUESTED
  APPROVED
  PAID
  REJECTED
  FAILED
}

enum RevenueType {
  SESSION
  SUBSCRIPTION
  CONTENT
}

enum SubscriptionDomain {
  PATIENT
  PROVIDER
}

enum SubscriptionPlan {
  BASIC
  PREMIUM
  LEAD_PLAN
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum WebhookProvider {
  RAZORPAY
}

enum WebhookProcessStatus {
  RECEIVED
  PROCESSED
  SKIPPED_DUPLICATE
  FAILED
}

enum FinancialAuditActorType {
  SYSTEM
  ADMIN
  WEBHOOK
  CRON
}

enum LeadStatus {
  AVAILABLE
  PURCHASED
  EXPIRED
  NO_RESPONSE
  ACCEPTED
}

enum LeadPaymentStatus {
  NOT_REQUIRED
  INITIATED
  CAPTURED
  FAILED
}

model FinancialSession {
  id                  String                 @id @default(uuid())
  patientId           String
  providerId          String
  status              FinancialSessionStatus @default(PENDING_PAYMENT)
  expectedAmountMinor BigInt
  currency            String                 @default("INR")
  idempotencyKey      String                 @unique
  razorpayOrderId     String?                @unique
  confirmedAt         DateTime?
  completedAt         DateTime?
  expiredAt           DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  patient            User                @relation("FinancialPatient", fields: [patientId], references: [id], onDelete: Restrict)
  provider           User                @relation("FinancialProvider", fields: [providerId], references: [id], onDelete: Restrict)
  payments           FinancialPayment[]  @relation("SessionPayments")
  walletTransactions WalletTransaction[] @relation("SessionWalletTransactions")
  revenueLedger      RevenueLedger[]     @relation("SessionRevenueLedger")

  @@index([patientId, status])
  @@index([providerId, status])
  @@index([createdAt])
  @@map("financial_sessions")
}

model Lead {
  id                      String     @id @default(uuid())
  patientId               String
  providerId              String?
  status                  LeadStatus @default(AVAILABLE)
  matchScore              Int?
  amountMinor             BigInt
  currency                String     @default("INR")
  previewData             Json?
  patientAcceptanceUntil  DateTime?
  providerContactedAt     DateTime?
  purchasedAt             DateTime?
  acceptedAt              DateTime?
  expiresAt               DateTime?
  paymentStatus           LeadPaymentStatus @default(NOT_REQUIRED)
  razorpayOrderId         String?           @unique
  razorpayPaymentId       String?           @unique
  paymentCapturedAt       DateTime?
  idempotencyKey          String?    @unique
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  patient  User  @relation("LeadPatient", fields: [patientId], references: [id], onDelete: Restrict)
  provider User? @relation("LeadProvider", fields: [providerId], references: [id], onDelete: Restrict)

  @@index([status, createdAt(sort: Desc)])
  @@index([providerId, status])
  @@index([providerId, paymentStatus])
  @@index([patientId, status])
  @@index([patientAcceptanceUntil])
  @@map("leads")
}

model FinancialPayment {
  id                    String                 @id @default(uuid())
  sessionId             String
  providerId            String
  providerGateway       String                 @default("RAZORPAY")
  razorpayOrderId       String                 @unique
  razorpayPaymentId     String?                @unique
  status                FinancialPaymentStatus @default(INITIATED)
  amountMinor           BigInt
  currency              String                 @default("INR")
  therapistShareMinor   BigInt                 @default(0)
  platformShareMinor    BigInt                 @default(0)
  captureIdempotencyKey String?                @unique
  capturedAt            DateTime?
  failedAt              DateTime?
  failureReason         String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  session            FinancialSession    @relation("SessionPayments", fields: [sessionId], references: [id], onDelete: Restrict)
  wallet             ProviderWallet      @relation("WalletPayments", fields: [providerId], references: [providerId], onDelete: Restrict)
  revenueLedger      RevenueLedger[]     @relation("PaymentRevenueLedger")
  walletTransactions WalletTransaction[] @relation("PaymentWalletTransactions")

  @@index([sessionId, status])
  @@index([providerId, status])
  @@index([razorpayOrderId])
  @@index([createdAt])
  @@map("financial_payments")
}

model ProviderWallet {
  providerId            String    @id
  pendingBalanceMinor   BigInt    @default(0)
  availableBalanceMinor BigInt    @default(0)
  lifetimeEarningsMinor BigInt    @default(0)
  isFrozen              Boolean   @default(false)
  frozenReason          String?
  frozenAt              DateTime?
  version               Int       @default(1)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  provider     User                @relation("ProviderWalletOwner", fields: [providerId], references: [id], onDelete: Restrict)
  transactions WalletTransaction[] @relation("WalletTransactions")
  payouts      PayoutRequest[]     @relation("WalletPayouts")
  payments     FinancialPayment[]  @relation("WalletPayments")

  @@index([isFrozen])
  @@index([updatedAt])
  @@map("provider_wallets")
}

model WalletTransaction {
  id                 String          @id @default(uuid())
  providerId         String
  walletTxnType      WalletTxnType
  status             WalletTxnStatus @default(POSTED)
  amountMinor        BigInt
  currency           String          @default("INR")
  balanceBeforeMinor BigInt
  balanceAfterMinor  BigInt
  sessionId          String?
  paymentId          String?
  payoutRequestId    String?
  revenueLedgerId    String?
  referenceKey       String?         @unique
  metadata           Json?
  createdAt          DateTime        @default(now())

  wallet  ProviderWallet    @relation("WalletTransactions", fields: [providerId], references: [providerId], onDelete: Restrict)
  session FinancialSession? @relation("SessionWalletTransactions", fields: [sessionId], references: [id], onDelete: Restrict)
  payment FinancialPayment? @relation("PaymentWalletTransactions", fields: [paymentId], references: [id], onDelete: Restrict)
  payout  PayoutRequest?    @relation("PayoutWalletTransactions", fields: [payoutRequestId], references: [id], onDelete: Restrict)
  revenue RevenueLedger?    @relation("RevenueWalletTransactions", fields: [revenueLedgerId], references: [id], onDelete: Restrict)

  @@index([providerId, createdAt(sort: Desc)])
  @@index([walletTxnType, createdAt(sort: Desc)])
  @@index([sessionId])
  @@index([paymentId])
  @@index([payoutRequestId])
  @@map("wallet_transactions")
}

model PayoutRequest {
  id                     String       @id @default(uuid())
  providerId             String
  amountMinor            BigInt
  currency               String       @default("INR")
  status                 PayoutStatus @default(REQUESTED)
  minWithdrawalRuleMinor BigInt       @default(10000)
  requestedAt            DateTime     @default(now())
  approvedAt             DateTime?
  paidAt                 DateTime?
  rejectedAt             DateTime?
  approvedByAdminId      String?
  rejectedByAdminId      String?
  rejectionReason        String?
  bankReference          String?      @unique
  idempotencyKey         String       @unique

  provider           ProviderWallet      @relation("WalletPayouts", fields: [providerId], references: [providerId], onDelete: Restrict)
  walletTransactions WalletTransaction[] @relation("PayoutWalletTransactions")

  @@index([providerId, status, requestedAt(sort: Desc)])
  @@index([status, requestedAt(sort: Desc)])
  @@map("payout_requests")
}

model MarketplaceSubscription {
  id                     String             @id @default(uuid())
  userId                 String
  domain                 SubscriptionDomain
  plan                   SubscriptionPlan
  status                 SubscriptionStatus @default(PAST_DUE)
  providerGateway        String             @default("RAZORPAY")
  razorpaySubscriptionId String             @unique
  razorpayPlanId         String
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  nextBillingDate        DateTime?
  cancelledAt            DateTime?
  expiredAt              DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user          User                  @relation("UserSubscriptions", fields: [userId], references: [id], onDelete: Restrict)
  invoices      SubscriptionInvoice[] @relation("SubscriptionInvoices")
  revenueLedger RevenueLedger[]       @relation("SubscriptionRevenueLedger")

  @@index([userId, domain, status])
  @@index([status, nextBillingDate])
  @@index([createdAt])
  @@map("marketplace_subscriptions")
}

model SubscriptionInvoice {
  id                String    @id @default(uuid())
  subscriptionId    String
  razorpayPaymentId String?   @unique
  amountMinor       BigInt
  currency          String    @default("INR")
  billedAt          DateTime
  nextBillingDate   DateTime?
  createdAt         DateTime  @default(now())

  subscription MarketplaceSubscription @relation("SubscriptionInvoices", fields: [subscriptionId], references: [id], onDelete: Restrict)

  @@index([subscriptionId, billedAt(sort: Desc)])
  @@map("subscription_invoices")
}

model RevenueLedger {
  id                      String      @id @default(uuid())
  type                    RevenueType
  grossAmountMinor        BigInt
  platformCommissionMinor BigInt
  providerShareMinor      BigInt
  taxAmountMinor          BigInt      @default(0)
  currency                String      @default("INR")
  referenceId             String
  paymentId               String?
  sessionId               String?
  subscriptionId          String?
  createdAt               DateTime    @default(now())

  payment            FinancialPayment?        @relation("PaymentRevenueLedger", fields: [paymentId], references: [id], onDelete: Restrict)
  session            FinancialSession?        @relation("SessionRevenueLedger", fields: [sessionId], references: [id], onDelete: Restrict)
  subscription       MarketplaceSubscription? @relation("SubscriptionRevenueLedger", fields: [subscriptionId], references: [id], onDelete: Restrict)
  walletTransactions WalletTransaction[]      @relation("RevenueWalletTransactions")

  @@index([type, createdAt(sort: Desc)])
  @@index([referenceId, createdAt(sort: Desc)])
  @@index([sessionId])
  @@index([subscriptionId])
  @@map("revenue_ledger")
}

model WebhookLog {
  id               String               @id @default(uuid())
  provider         WebhookProvider      @default(RAZORPAY)
  eventId          String
  eventType        String
  payloadHash      String
  signature        String
  isSignatureValid Boolean
  processStatus    WebhookProcessStatus @default(RECEIVED)
  firstSeenAt      DateTime             @default(now())
  processedAt      DateTime?
  errorMessage     String?
  sessionId        String?
  subscriptionId   String?
  rawPayload       Json

  @@unique([provider, eventId])
  @@index([eventType, processStatus])
  @@index([firstSeenAt])
  @@map("webhook_logs")
}

model FinancialAuditLog {
  id         String                  @id @default(uuid())
  actorType  FinancialAuditActorType
  actorId    String?
  action     String
  entityType String
  entityId   String
  reason     String?
  beforeJson Json?
  afterJson  Json?
  traceId    String?
  createdAt  DateTime                @default(now())

  actor User? @relation("UserFinancialAudits", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([actorType, createdAt(sort: Desc)])
  @@index([traceId])
  @@map("financial_audit_logs")
}
